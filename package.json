{
  "name": "json-editor",
  "version": "1.0.0",
  "description": "A modern JSON editor with schema validation",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp src/renderer/index.html dist/renderer/",
    "start": "npm run build && electron .",
    "dev": "concurrently \"tsc -w\" \"electron .\"",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write src/**/*.{ts,tsx,css}",
    "prepare": "husky install"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.263.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.13",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^8.2.1",
    "electron": "^27.0.2",
    "eslint": "^8.57.1",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "prettier": "^3.0.3",
    "typescript": "~5.3.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,css}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
